generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id             Int      @id @default(1)
  heroTitle      String   @map("hero_title")
  heroSubtitle   String   @map("hero_subtitle")
  productSignals Json     @map("product_signals")
  aboutShort     String   @map("about_short")
  footerIntro    String   @map("footer_intro")
  contactEmail   String   @map("contact_email")
  githubUrl      String   @map("github_url")
  linkedinUrl    String   @map("linkedin_url")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Writing {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String
  body        String
  tags        String[]
  category    String?
  series      String?
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  readingTime Int?      @map("reading_time")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("writing")
}

model Project {
  id                     String    @id @default(cuid())
  title                  String
  slug                   String    @unique
  summary                String
  body                   String
  tags                   String[]
  featured               Boolean   @default(false)
  published              Boolean   @default(false)
  publishedAt            DateTime? @map("published_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  role                   String
  stack                  String[]
  platform               String?
  problem                String
  solution               String
  architectureHighlights String[]  @map("architecture_highlights")
  decisions              String[]
  outcomes               String[]
  repoUrl                String?   @map("repo_url")
  liveUrl                String?   @map("live_url")
  timeline               String?

  @@map("projects")
}

model Work {
  id                   String    @id @default(cuid())
  title                String
  slug                 String    @unique
  summary              String
  body                 String
  tags                 String[]
  featured             Boolean   @default(false)
  published            Boolean   @default(false)
  publishedAt          DateTime? @map("published_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  client               String
  engagementType       String    @map("engagement_type")
  role                 String
  timeline             String?
  confidentialityLevel String?   @map("confidentiality_level")
  scope                String[]
  responsibilities     String[]
  constraints          String[]
  impact               String[]

  @@map("work")
}

model Lab {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String
  body        String
  tags        String[]
  status      String
  featured    Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("labs")
}
